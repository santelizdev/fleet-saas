[Unit]
Description=Fleet SaaS Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/fleet/backend
Environment="DJANGO_SETTINGS_MODULE=config.settings"
EnvironmentFile=/opt/fleet/.env
ExecStart=/opt/fleet/.venv/bin/gunicorn config.wsgi:application \
  --bind 127.0.0.1:8000 \
  --workers 3 \
  --timeout 60 \
  --access-logfile - \
  --error-logfile -
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
