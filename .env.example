# Entorno base Django / Docker
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.com,www.tu-dominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
DJANGO_USE_HTTPS_HEADERS=1

# Base de datos y Redis
DATABASE_URL=postgres://fleet:fleet@db:5432/fleet
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# Branding / soporte
SUPPORT_EMAIL=soporte@tu-dominio.com
SUPPORT_WHATSAPP=+56 9 0000 0000

# Límites / reportes
REPORT_MAX_EXPORT_ROWS=5000
REPORT_MAX_EXPORTS_PER_DAY=20
RATE_LIMIT_REPORTS_PER_MIN=60
DEFAULT_MAX_VEHICLES=100
DEFAULT_MAX_USERS=50
DEFAULT_MAX_STORAGE_MB=1024
DEFAULT_MAX_UPLOADS_PER_DAY=200
DEFAULT_MAX_EXPORTS_PER_DAY=20

# Alertas programadas
ALERT_DEFAULT_MAINTENANCE_REMINDER_DAYS=7
ALERT_DEFAULT_MAINTENANCE_REMINDER_KM=500
ALERT_GENERATION_BATCH_SIZE=500

# Email de notificaciones
DEFAULT_FROM_EMAIL=notificaciones@tu-dominio.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.tu-proveedor.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=notificaciones@tu-dominio.com
DJANGO_EMAIL_HOST_PASSWORD=change-me
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_USE_SSL=0

# Push notifications
# console: útil para pruebas iniciales, deja trazas en logs
# webhook: envía POST a tu servicio/microservicio de push (FCM, OneSignal, Web Push, etc.)
NOTIFICATION_PUSH_BACKEND=console
NOTIFICATION_PUSH_WEBHOOK_URL=
NOTIFICATION_PUSH_WEBHOOK_TOKEN=
